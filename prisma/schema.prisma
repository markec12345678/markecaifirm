// Prisma schema for Markec AI Firm — Opportunity Monitor

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Single-row table storing app configuration (AI provider, Telegram, etc.)
model Settings {
  id              String   @id @default("singleton")
  // AI provider config
  aiProvider      String   @default("ollama") // ollama | openai | anthropic | openai-compatible
  aiBaseUrl       String   @default("http://localhost:11434")
  aiApiKey        String   @default("")
  aiModel         String   @default("qwen2.5:7b")
  // v2.6: AI fallback — when primary provider fails, use fallback
  fallbackProvider String  @default("") // empty = disabled
  fallbackBaseUrl  String  @default("")
  fallbackApiKey   String  @default("")
  fallbackModel    String  @default("")
  // Telegram config
  telegramBotToken String  @default("")
  telegramChatId   String  @default("")
  telegramEnabled  Boolean @default(false)
  // v1.4: Discord webhook
  discordWebhookUrl String @default("")
  discordEnabled   Boolean @default(false)
  // v2.1: Slack webhook
  slackWebhookUrl  String  @default("")
  slackEnabled     Boolean  @default(false)
  // Heartbeat
  heartbeatEnabled Boolean @default(true)
  heartbeatHour    Int     @default(22) // 22:00 local
  lastHeartbeatAt  DateTime?
  // Thresholds
  minOpportunityScore Int  @default(7)   // 1-10 — alert only when AI score >= this
  maxRiskScore        Int  @default(3)   // 1-10 — alert only when AI risk <= this
  // Image analysis (v1.1)
  imageAnalysisEnabled Boolean @default(false)
  // Bolha Playwright fallback (v1.1)
  playwrightEnabled    Boolean @default(false)
  // Telegram inline buttons (v1.1)
  telegramInlineButtons Boolean @default(true)
  // Webhook secret for Telegram callback queries (v1.1)
  telegramWebhookSecret String @default("")
  // v1.5: Web Push notifications (VAPID)
  pushEnabled          Boolean @default(false)
  vapidPublicKey       String  @default("")
  vapidPrivateKey      String  @default("")
  // v1.6: Digest mode (namesto instant alerts)
  digestMode           String  @default("instant") // instant | daily | weekly
  digestHour           Int     @default(20) // 20:00 local
  // v1.6: Quick response templates (JSON array of {name, text} objects)
  quickResponseTemplates String @default("[]")
  // v2.2: Notification quiet hours — don't send alerts during these hours
  quietHoursEnabled    Boolean @default(false)
  quietStartHour       Int     @default(22) // 22:00
  quietEndHour         Int     @default(7)  // 07:00
  // v2.2: Auto-cleanup — automatically archive/delete old data
  autoCleanupEnabled   Boolean @default(false)
  autoCleanupAlertsDays Int    @default(30) // archive alerts older than N days
  autoCleanupListingsDays Int  @default(90) // delete listings older than N days
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// v1.5: Push subscription — stores browser push endpoints
model PushSubscription {
  id          String   @id @default(cuid())
  endpoint    String   @unique // browser push endpoint URL
  p256dh      String   // user agent public key
  auth        String   // auth secret
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// v1.6: Trade — tracks bought + sold listings for profit calculation
model Trade {
  id          String   @id @default(cuid())
  // Link to original listing (nullable if user manually adds)
  listingId   String?
  listing     Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  // Item details (denormalized so manual trades work without listing)
  title       String
  category    String   @default("") // npr. "elektronika", "avto", "nepremičnina"
  imageUrl    String?
  url         String?
  // Buy side
  buyPrice    Float    // EUR
  buyDate     DateTime @default(now())
  buyLocation String   @default("") // kje kupljeno (Bolha, FB, trgovina)
  buyFees     Float    @default(0) // pristojbine, šhiping pri nakupu
  // Sell side (null if not yet sold)
  sellPrice   Float?
  sellDate    DateTime?
  sellLocation String  @default("") // kje prodano
  sellFees    Float    @default(0) // pristojbine pri prodaji
  // Status
  status      String   @default("held") // held | sold | cancelled
  // Notes
  notes       String   @default("")
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, buyDate])
  @@index([category])
}

// v1.6: Digest log — when digests were sent (for scheduling)
model DigestLog {
  id          String   @id @default(cuid())
  sentAt      DateTime @default(now())
  type        String   // daily | weekly
  listingsCount Int    @default(0)
  alertsCount Int      @default(0)
  topOpportunities Int @default(0)
  sentTelegram Boolean @default(false)
  sentDiscord  Boolean @default(false)
  sentPush     Boolean @default(false)
  message     String
}

// A configured search monitor (e.g. "iPhone 13 Pro on Bolha", "2-sobno LJ na Nepremicnine")
model Monitor {
  id          String   @id @default(cuid())
  name        String
  source      String   // bolha | nepremicnine | avtonet | salomon | custom-rss
  sourceUrl   String   // the search URL or RSS URL
  // Optional filters
  keywords    String   @default("") // comma-separated, must appear in title/description
  excludeKeywords String @default("")
  minPrice    Int?
  maxPrice    Int?
  // Schedule
  intervalMinutes Int @default(30)
  isActive   Boolean  @default(true)
  // v1.2: schedule window — only run during these hours (e.g. "6-23"). Empty = always.
  runStartHour Int?
  runEndHour   Int?
  lastRunAt  DateTime?
  lastStatus String?  // ok | error | empty
  lastError  String?
  // v1.3: auto-pause after N consecutive errors
  consecutiveErrors Int @default(0)
  autoPauseThreshold Int @default(5)  // 0 = disabled, otherwise pause after N consecutive errors
  autoPausedAt DateTime?
  // v2.2: Monitor-specific notification channels (JSON: {telegram, discord, slack, push})
  notificationChannels String @default("{}") // empty = use global settings
  // AI prompt customization (optional)
  customPrompt String @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listings   Listing[]
  alerts     Alert[]
  runLogs    RunLog[]
}

// A scraped listing — kept for deduplication & history
model Listing {
  id          String   @id @default(cuid())
  monitorId   String
  monitor     Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  externalId  String   // unique listing id from source (URL hash)
  title       String
  price       Int?     // EUR
  priceText   String   // raw price text (e.g. "Po dogovoru")
  url         String
  location    String   @default("")
  description String   @default("")
  imageUrl    String?
  postedAt    DateTime?
  firstSeenAt DateTime @default(now())
  // AI evaluation (cached)
  aiScore        Int?      // 1-10 opportunity score
  aiRisk         Int?      // 1-10 risk score
  aiVerdict      String?   // PRILIKA | SUMNJIVO | NEZANIMIVO
  aiReason       String?
  aiEstimatedValue Int?    // EUR — what AI thinks fair market value is
  aiEvaluatedAt  DateTime?
  // Image analysis (v1.1)
  aiImageAnalysis String?  // AI description of the listing image
  aiImageVerdict  String?  // AUTHENTIC | SUSPICIOUS | STOCK_PHOTO | NO_IMAGE
  // v1.4: bookmark/favorite
  isBookmarked    Boolean  @default(false)
  bookmarkedAt    DateTime?
  // v1.4: full detail page data (Bolha detail page scraper)
  detailDescription String? // full description from detail page (longer than listing description)
  detailImages      String? // JSON array of all image URLs
  detailFetchedAt   DateTime?
  // v2.0: seller tracking (extracted from listing URL or description)
  sellerName       String?
  sellerListingCount Int   @default(0) // how many listings this seller has
  // v2.0: price drop tracking
  previousPrice    Int?    // last known price before current (for drop detection)
  priceDroppedAt   DateTime? // when the price last dropped
  // v2.4: Personal notes (user's own notes about this listing)
  userNotes        String?
  userNotesUpdatedAt DateTime?
  // v2.4: Contact tracking
  contactStatus    String   @default("none") // none | contacted | responded | closed
  contactedAt      DateTime?
  sellerResponse   String?
  // Alerts generated for this listing
  alerts      Alert[]
  priceHistory PriceHistory[]
  // v1.6: Trade (if this listing was bought)
  trades      Trade[]

  @@unique([monitorId, externalId])
  @@index([monitorId, firstSeenAt])
  @@index([aiVerdict, aiScore])
  @@index([isBookmarked, firstSeenAt])
  @@index([price])
  @@index([sellerName])
}

// An alert that was sent (Telegram/email/dashboard)
model Alert {
  id          String   @id @default(cuid())
  monitorId   String
  monitor     Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  listingId   String?
  listing     Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  title       String
  body        String
  url         String
  aiScore     Int?
  aiRisk      Int?
  aiVerdict   String?
  // Delivery
  sentTelegram Boolean @default(false)
  telegramSentAt DateTime?
  telegramError String?
  // UI state
  isRead      Boolean  @default(false)
  isArchived  Boolean  @default(false)
  // v1.2: user feedback for AI accuracy tracking
  userAction  String?  // interested | archived | scam | ignored (auto-set after 7 days)
  userActionedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([monitorId, createdAt])
  @@index([isArchived, createdAt])
  @@index([userAction])
}

// Run log — every monitor execution record
model RunLog {
  id          String   @id @default(cuid())
  monitorId   String
  monitor     Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  status      String   // ok | error | empty
  listingsFound Int    @default(0)
  newListings  Int     @default(0)
  alertsSent   Int     @default(0)
  error       String?
  durationMs  Int?

  @@index([monitorId, startedAt])
}

// Heartbeat log — daily system health report (v1.1)
model HeartbeatLog {
  id            String   @id @default(cuid())
  sentAt        DateTime @default(now())
  periodStart   DateTime
  periodEnd     DateTime
  totalRuns     Int      @default(0)
  successfulRuns Int     @default(0)
  failedRuns    Int      @default(0)
  totalListings Int      @default(0)
  newListings   Int      @default(0)
  totalAlerts   Int      @default(0)
  prilikaAlerts Int      @default(0)
  sumnjivoAlerts Int     @default(0)
  activeMonitors Int     @default(0)
  sentTelegram  Boolean  @default(false)
  telegramError String?
  message       String
}

// v1.4: Price history — tracks price changes of a listing over time
model PriceHistory {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  price       Int?     // EUR — null if "po dogovoru"
  priceText   String   // raw text
  seenAt      DateTime @default(now())

  @@index([listingId, seenAt])
}
